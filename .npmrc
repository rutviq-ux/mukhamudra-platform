# pnpm configuration for monorepo
# https://pnpm.io/npmrc

# Enable interactive TUI reporter
reporter=default
color=always

# Link workspace packages automatically
link-workspace-packages=true

# Hoist all dependencies to root node_modules
hoist-pattern[]=*

# Don't publicly hoist anything (for strict isolation)
public-hoist-pattern[]=

# Use the lockfile version matching pnpm 9+
use-lockfile-v9=true
registry=https://registry.npmjs.org
